@inject CompanioNationSignalRClient SignalRClient
@inject IJSRuntime JSRuntime

<div @ref="ShadowContainer"></div>

@code {

    private string? _renderedHtml;

    [Parameter, EditorRequired]
    public string Html { get; set; } = string.Empty;

    private ElementReference ShadowContainer;
    private IJSObjectReference? module;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            module = await JSRuntime.ImportModuleAsync("/Components/ShadowDomElement.razor.js", SignalRClient.LogError);
        }

        // Paint whenever the module is ready and the current Html hasn't been
        // pushed to the shadow root yet. This runs after every render, so it can
        // never be stranded blank by a first-render/import race or by the value
        // being set before the JS module finished loading.
        if (module is not null && _renderedHtml != Html)
        {
            _renderedHtml = Html;
            try
            {
                await JSRuntime.InvokeVoidAsync("loadHtmlIntoShadowDOM", ShadowContainer, Html);
            }
            catch (Exception ex)
            {
                SignalRClient.LogError(ex);
            }
        }
    }

    public void Dispose()
    {
        if (module is not null)
        {
            module.DisposeAsync();
        }
    }

}
