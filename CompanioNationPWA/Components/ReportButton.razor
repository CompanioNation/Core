@using CompanioNation.Shared

<button type="button" class="report-btn" @onclick="ShowDialog" title="Report" aria-label="Report this user">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="1.2em" height="1.2em" fill="currentColor">
        <path d="M14.4 6l-.24-1.2A1 1 0 0 0 13.18 4H6v16h2v-6h4.6l.24 1.2a1 1 0 0 0 .98.8H20V6h-5.6z"/>
    </svg>
    Report
</button>

@if (_showDialog)
{
    <div class="report-overlay" @onclick="HideDialog">
        <div class="report-dialog" @onclick:stopPropagation="true">
            <h3>Report User</h3>

            <label for="report-reason">Reason</label>
            <select id="report-reason" @bind="_selectedReason">
                <option value="@ReportReasons.Harassment">Harassment</option>
                <option value="@ReportReasons.Spam">Spam</option>
                <option value="@ReportReasons.HateSpeech">Hate Speech</option>
                <option value="@ReportReasons.ExplicitContent">Explicit Content</option>
                <option value="@ReportReasons.Impersonation">Impersonation</option>
                <option value="@ReportReasons.Other">Other</option>
            </select>

            <label for="report-detail">Details (optional)</label>
            <textarea id="report-detail" @bind="_detail" maxlength="500" rows="3" placeholder="Provide additional details..."></textarea>

            @if (!string.IsNullOrEmpty(_resultMessage))
            {
                <p class="report-result @(_isError ? "error" : "success")">@_resultMessage</p>
            }

            <div class="report-actions">
                <button type="button" class="btn-cancel" @onclick="HideDialog">Cancel</button>
                <ActionButton OnClick="SubmitReport" Color="#e57373">Submit Report</ActionButton>
            </div>
        </div>
    </div>
}

@code {
    [Parameter, EditorRequired]
    public int ReportedUserId { get; set; }

    [Parameter]
    public int ReportType { get; set; } = ReportTypes.Profile;

    [Parameter]
    public int? ReferenceId { get; set; }

    [Parameter]
    public CompanioNationSignalRClient SignalRClient { get; set; } = default!;

    private bool _showDialog;
    private int _selectedReason = ReportReasons.Harassment;
    private string _detail = string.Empty;
    private string _resultMessage = string.Empty;
    private bool _isError;

    private void ShowDialog() { _showDialog = true; _resultMessage = string.Empty; }
    private void HideDialog() { _showDialog = false; }

    private async Task SubmitReport()
    {
        var request = new ReportRequest(ReportedUserId, ReportType, _selectedReason, string.IsNullOrWhiteSpace(_detail) ? null : _detail.Trim(), ReferenceId);
        var result = await SignalRClient.ReportUserAsync(request);
        if (result != null)
        {
            _isError = false;
            _resultMessage = "Report submitted. Thank you.";
            _detail = string.Empty;
            await Task.Delay(2000);
            HideDialog();
        }
        else
        {
            _isError = true;
            _resultMessage = "Unable to submit report. Please try again.";
        }
    }
}
