@inject CompanioNationSignalRClient SignalRClient
@inject IJSRuntime JSRuntime
@implements IAsyncDisposable

<button class="feedbackButtonClass" aria-label="Send feedback">
    <img src="/images/feedback-icon.png" alt="Feedback" draggable="false" />
</button>

@if (showPopup)
{
    <div class="blurred-background" @onclick="CancelPopup"></div>
    <div class="popupClass">
        <textarea @bind="feedbackText" @bind:event="oninput" placeholder="Enter your feedback here..." maxlength="2000"></textarea>
        <div class="popup-buttons">
            <button class="sendButton" @onclick="SubmitFeedback" disabled="@isSubmitDisabled">
                <span class="send-icon">▶</span> Send
            </button>
            <button class="cancelButton" @onclick="CancelPopup">Cancel</button>
        </div>
    </div>
}

@if (showThankYouMessage)
{
    <div class="thank-you-message">Thank you for your feedback!</div>
}

@code {
    private bool showPopup;
    private bool showThankYouMessage;
    private string feedbackText = string.Empty;
    private bool isSubmitDisabled => string.IsNullOrWhiteSpace(feedbackText);
    private IJSObjectReference? module;
    private DotNetObjectReference<FeedbackButton>? dotNetRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            dotNetRef = DotNetObjectReference.Create(this);
            module = await JSRuntime.ImportModuleAsync("/Components/FeedbackButton.razor.js", SignalRClient.LogError);
            if (module is not null)
            {
                await module.InvokeVoidAsync("initializeFeedbackButton", dotNetRef);
            }
        }
    }

    [JSInvokable]
    public void ShowPopup()
    {
        showPopup = true;
        StateHasChanged();
    }

    private void CancelPopup()
    {
        showPopup = false;
        feedbackText = string.Empty;
    }

    private async Task SubmitFeedback()
    {
        if (!string.IsNullOrWhiteSpace(feedbackText))
        {
            try
            {
                await SignalRClient.Initialize();
                await SignalRClient.SendFeedback(feedbackText);

                feedbackText = string.Empty;
                showPopup = false;
                showThankYouMessage = true;

                await Task.Delay(3000);
                showThankYouMessage = false;
            }
            catch (Exception ex)
            {
                await SignalRClient.LogError(ex, "SubmitFeedback");
            }
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (module is not null)
        {
            await module.DisposeAsync();
        }
        dotNetRef?.Dispose();
    }
}
