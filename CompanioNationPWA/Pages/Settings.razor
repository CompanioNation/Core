@page "/Settings"
@inject IJSRuntime JSRuntime
@inject CompanioNationSignalRClient SignalRClient
@inject NavigationManager NavManager
@inject HttpClient Http
@using CompanioNation.Shared
@using CompanioNationPWA.CitySelect

<Information Content="@(new MarkupString(@"
<h2>Settings Page</h2>
<p>On this page, you can update your personal details to keep your profile information accurate and up-to-date.</p>
<p>You also have control over which guaranteed photos and reviews are visible to others. Adjust your visibility settings to share only the content you’re comfortable with.</p>
<p>Use the Profile Visibility toggle to hide your profile from search results at any time. If you decide to leave, you can delete your profile — but we'll suggest hiding it first so you don't lose your message history and CompanioNita conversations.</p>
"))" />

<h3>Settings</h3>

<div class="settings-container">
    @if (SignalRClient.CurrentUser == null)
    {
        <p>Loading user information...</p>
    }
    else
    {
        <div class="header">
            <h4>@SignalRClient.CurrentUser.Name</h4>
            <button class="btn btn-danger shadow-lg rounded-pill" @onclick="HandleLogout">Log Out</button>
        </div>

        @if (SignalRClient.CurrentUser.IsAdministrator)
        {
            <div class="admin-section">
                <NavLink href="/Admin" class="admin-panel-link">
                    <span class="admin-panel-link-icon">⚙</span>
                    <span class="admin-panel-link-text">
                        <strong>Admin Panel</strong>
                        <span>Manage users, run maintenance</span>
                    </span>
                    <span class="admin-panel-link-arrow">›</span>
                </NavLink>
            </div>
        }

        <div class="compact-info">
            <div class="info-item">
                <b>LINK Score:</b> @SignalRClient.CurrentUser.Ranking
            </div>

            <div class="info-item">
                <b>Last Login:</b> @SignalRClient.CurrentUser.LastLogin?.ToLocalTime().ToString("g")
            </div>

            <div class="info-item">
                <b>Email:</b> @SignalRClient.CurrentUser.Email
            </div>

            <div class="info-item">
                <b>Member since:</b> @ConvertToLocalTime(SignalRClient.CurrentUser.DateCreated).ToShortDateString()
            </div>
        </div>

        @if (!_subscriptionMessageDismissed && !string.IsNullOrEmpty(SubscriptionStatus))
        {
            <div class="alert @(SubscriptionStatus == "success" ? "alert-success" : "alert-warning") alert-dismissible" role="alert">
                @if (SubscriptionStatus == "success")
                {
                    // Here we don't need to re-load the user data to get the updated subscription expiry because that will have happened by virtue of the fact that we came from an external link
                    <span><strong>Subscription updated!</strong> Your subscription has been successfully created or updated.</span>
                }
                else if (SubscriptionStatus == "cancelled")
                {
                    <span><strong>Checkout cancelled.</strong> Your subscription was not changed.</span>
                }
                <button type="button" class="btn-close" @onclick="DismissSubscriptionMessage"></button>
            </div>
        }

        @if (SignalRClient.CurrentUser.SubscriptionExpiry.HasValue && SignalRClient.CurrentUser.SubscriptionExpiry.Value > DateTime.UtcNow)
        {
            <div class="subscription-section">
                <h4>Subscription</h4>
                <p><b>Status:</b> Active</p>
                <p><b>Expires:</b> @SignalRClient.CurrentUser.SubscriptionExpiry.Value.ToString("MMMM dd, yyyy")</p>

                @if (!string.IsNullOrEmpty(_subscriptionErrorMessage))
                {
                    <div class="alert alert-danger">@_subscriptionErrorMessage</div>
                }

                @if (!string.IsNullOrEmpty(_subscriptionSuccessMessage))
                {
                    <div class="alert alert-success">@_subscriptionSuccessMessage</div>
                }

                @if (_canCancelInline)
                {
                    @if (_showCancelConfirmation)
                    {
                        <div class="alert alert-warning">
                            <p><strong>Are you sure you want to cancel your subscription?</strong></p>
                            <p>Your access will continue until the end of your current billing period.</p>
                            <div style="display:flex; gap:8px; margin-top:8px;">
                                <ActionButton OnClick="ConfirmCancelSubscription">
                                    Yes, Cancel
                                </ActionButton>
                                <button class="grayButton" @onclick="DismissCancelConfirmation">No, Keep It</button>
                            </div>
                        </div>
                    }
                    else
                    {
                        <ActionButton OnClick="CancelSubscription">
                            Cancel Subscription
                        </ActionButton>
                    }
                }
                else if (!string.IsNullOrEmpty(_manageSubscriptionUrl))
                {
                    <ActionButton OnClick="ManageSubscriptionExternal">
                        Manage Subscription
                    </ActionButton>
                }
            </div>
        }


        <EditForm EditContext="_editContext">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="editable-fields">
                <label>Name:</label>
                <InputText @bind-Value="SignalRClient.CurrentUser.Name" class="form-control" />

                <label>Description:</label>
                <InputTextArea @bind-Value="SignalRClient.CurrentUser.Description" class="form-control" />

                <label>Gender:</label>
                <InputSelect @bind-Value="SignalRClient.CurrentUser.Gender" class="form-control">
                    <option value="2">@Util.GetGenderString(2)</option>
                    <option value="4">@Util.GetGenderString(4)</option>
                    <option value="8">@Util.GetGenderString(8)</option>
                    <option value="16">@Util.GetGenderString(16)</option>
                    <option value="32">@Util.GetGenderString(32)</option>
                </InputSelect>

                <label>Date of Birth:</label>
                <InputDate @bind-Value="SignalRClient.CurrentUser.DateOfBirth" class="form-control" />
                <ValidationMessage For="@(() => SignalRClient.CurrentUser.DateOfBirth)" />

                <label>City:</label>
                <div class="city-select-container">
                    <CitySelect OnCitySelected="HandleCitySelected"></CitySelect>
                </div>
                <ValidationMessage For="@(() => SignalRClient.CurrentUser.Geonameid)" />
            </div>

            <div class="button-container">
                <ActionButton OnClick="UpdateUserInfo">
                    Save Changes
                </ActionButton>
            </div>
        </EditForm>

        <div class="profile-visibility-section">
            <h4>Profile Visibility</h4>
            <p class="visibility-description">Control whether other users can discover your profile in search results and browsing.</p>

            <div class="visibility-toggle-row">
                <span class="visibility-label">@(_profileVisible ? "Visible to others" : "Hidden from others")</span>
                <label class="toggle-switch">
                    <input type="checkbox" checked="@_profileVisible" @onchange="HandleVisibilityToggle" />
                    <span class="toggle-slider"></span>
                </label>
            </div>

            @if (!string.IsNullOrEmpty(_visibilityMessage))
            {
                <div class="alert alert-info visibility-feedback">@_visibilityMessage</div>
            }

            <div class="delete-profile-zone">
                @if (_deleteStep == DeleteStep.None)
                {
                    <button class="btn-delete-profile" @onclick="StartDeleteFlow">Delete My Profile</button>
                }
                else if (_deleteStep == DeleteStep.SuggestHide)
                {
                    <div class="alert alert-warning delete-dialog">
                        <p><strong>Before you go — have you considered hiding your profile instead?</strong></p>
                        <p>Hiding keeps your message history, CompanioNita conversations, and account intact so you can come back anytime without starting over.</p>
                        <div class="delete-dialog-actions">
                            <button class="btn-hide-instead" @onclick="HideInstead">Hide My Profile Instead</button>
                            <button class="btn-delete-continue" @onclick="ProceedToConfirmDelete">No, Delete Permanently</button>
                            <button class="grayButton" @onclick="CancelDelete">Cancel</button>
                        </div>
                    </div>
                }
                else if (_deleteStep == DeleteStep.ConfirmDelete)
                {
                    <div class="alert alert-danger delete-dialog">
                        <p><strong>This action cannot be undone.</strong></p>
                        <p>Your profile details and photos will be removed. Your message history will be preserved but your name will show as "Deleted User".</p>
                        <div class="delete-dialog-actions">
                            <ActionButton Color="#dc3545" OnClick="ConfirmDeleteProfile">
                                Yes, Delete My Profile
                            </ActionButton>
                            <button class="grayButton" @onclick="CancelDelete">Cancel</button>
                        </div>
                    </div>
                }

                @if (!string.IsNullOrEmpty(_deleteErrorMessage))
                {
                    <div class="alert alert-danger">@_deleteErrorMessage</div>
                }
            </div>
        </div>

        <div class="user-images">
            <h4>Your Images</h4>
            <label for="photoUpload">Upload a new picture:</label>
            <InputFile id="photoUpload" OnChange="HandleProfilePictureUpload" disabled="@_isUploading" />

            @if (_isUploading)
            {
                <div class="alert alert-info" role="status">
                    Uploading and processing photo...
                </div>
            }

            @if (!string.IsNullOrEmpty(_fileErrorMessage))
            {
                <div class="alert alert-danger">
                    @_fileErrorMessage
                </div>
            }
            @if (_userImages != null && _userImages.Any())
            {
                <div class="image-gallery">
                    @foreach (var image in _userImages)
                    {
                        <div class="image-item">
                            <ThumbnailComponent ImageUrl="@Util.GetPhotoUrl(image.ImageGuid)" Alt="User Image" ThumbnailSize="6em"></ThumbnailComponent>
                            <p>Uploaded: @image.DateCreated.ToShortDateString()</p>
                            <label>Visible:</label>
                            <input type="checkbox" checked="@image.ImageVisible" @onchange="(e) => ToggleImageVisibility(image, ((ChangeEventArgs)e).Value)" />
                        </div>
                    }
                </div>

                <br />
                <h4>Your Reviews</h4>
                <div class="review-gallery">
                    @foreach (var image in _userImages)
                    {
                        @if (!string.IsNullOrWhiteSpace(image.Review))
                        {
                            <div class="review-item">
                                <p><strong>Review:</strong> @image.Review</p>
                                <label>Publicly Visible:</label>
                                <input type="checkbox" checked="@image.ReviewVisible" @onchange="(e) => ToggleReviewVisibility(image, ((ChangeEventArgs)e).Value)" />
                            </div>
                        }
                    }
                </div>
            }
            else
            {
                <p>No images or reviews uploaded yet.</p>
            }
        </div>

        <div class="actions">
            <a href="mailto:info@companionation.com" class="contact-link">Contact Us</a>
            <p class="policy-text">By Using CompanioNation™, you Agree to the <NavLink href="/PrivacyPolicy">Privacy Policy</NavLink></p>
        </div>
    }

</div>

@code {
[CascadingParameter] public MainLayout MainLayoutInstance { get; set; }

[SupplyParameterFromQuery(Name = "subscription")]
public string? SubscriptionStatus { get; set; }

private List<UserImage> _userImages = new List<UserImage>();
private EditContext? _editContext;
private string _fileErrorMessage = string.Empty;
private bool _isUploading;
private string _subscriptionErrorMessage = string.Empty;
private string _subscriptionSuccessMessage = string.Empty;
private bool _subscriptionMessageDismissed;
private bool _showCancelConfirmation;
private bool _canCancelInline = true;
private string? _manageSubscriptionUrl;

// Profile Visibility & Delete
private bool _profileVisible;
private string _visibilityMessage = string.Empty;
private DeleteStep _deleteStep = DeleteStep.None;
private string _deleteErrorMessage = string.Empty;

private enum DeleteStep { None, SuggestHide, ConfirmDelete }


    protected override async Task OnInitializedAsync()
    {
        _editContext = new EditContext(new UserDetails());
    }

    protected async override Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await SignalRClient.Initialize();
            if (SignalRClient.CurrentUser != null)
            {
                _editContext = new EditContext(SignalRClient.CurrentUser);
                _profileVisible = SignalRClient.CurrentUser.Searchable;
                _userImages = await SignalRClient.GetUserImagesAsync();
                _userImages = _userImages
                    .OrderByDescending(i => i.DateCreated)
                    .ToList();

                if (SignalRClient.CurrentUser.SubscriptionExpiry.HasValue
                    && SignalRClient.CurrentUser.SubscriptionExpiry.Value > DateTime.UtcNow)
                    await FetchCancelInfoAsync();
            }
            StateHasChanged();
        }
    }

    private async Task HandleLogout()
    {
        if (MainLayoutInstance != null)
        {
            MainLayoutInstance.Logout();
        }
        else
        {
            // Handle the case where MainLayoutInstance is null
            //_errorMessage = "Unable to logout. Please try again later.";
        }
    }

    private async Task HandleCitySelected(City city)
    {
        SignalRClient.CurrentUser.Geonameid = city.Geonameid;
        await UpdateUserInfo();
    }

    private DateTime ConvertToLocalTime(DateTime dateTime)
    {
        return dateTime.ToLocalTime();
    }

    private async Task UpdateUserInfo()
    {
        bool result = await SignalRClient.UpdateUserDetailsAsync(SignalRClient.CurrentUser);
        if (result == false) throw new Exception();
    }

    private void DismissSubscriptionMessage()
    {
        _subscriptionMessageDismissed = true;
    }

    private Task CancelSubscription()
    {
        _subscriptionErrorMessage = string.Empty;
        _subscriptionSuccessMessage = string.Empty;
        _showCancelConfirmation = true;
        return Task.CompletedTask;
    }

    private void DismissCancelConfirmation()
    {
        _showCancelConfirmation = false;
    }

    private async Task ConfirmCancelSubscription()
    {
        _showCancelConfirmation = false;
        _subscriptionErrorMessage = string.Empty;
        _subscriptionSuccessMessage = string.Empty;

        string? loginToken = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "loginGuid");
        if (string.IsNullOrWhiteSpace(loginToken))
        {
            _subscriptionErrorMessage = "You must be logged in to cancel your subscription.";
            return;
        }

        try
        {
            var response = await Http.PostAsync(
                $"api/billing/cancel-subscription?loginToken={Uri.EscapeDataString(loginToken)}", null);

            var message = await response.Content.ReadAsStringAsync();

            if (response.IsSuccessStatusCode)
            {
                _subscriptionSuccessMessage = message;
            }
            else
            {
                _subscriptionErrorMessage = string.IsNullOrWhiteSpace(message)
                    ? "Unable to cancel subscription. Please contact support@companionation.com."
                    : message;
            }
        }
        catch
        {
            _subscriptionErrorMessage = "Unable to cancel subscription. Please contact support@companionation.com.";
        }
    }

    private async Task FetchCancelInfoAsync()
    {
        try
        {
            var response = await Http.GetAsync("api/billing/cancel-info");
            if (response.IsSuccessStatusCode)
            {
                var json = await response.Content.ReadFromJsonAsync<CancelInfoResponse>();
                if (json != null)
                {
                    _canCancelInline = json.CanCancelInline;
                    _manageSubscriptionUrl = json.ManageUrl;
                }
            }
        }
        catch
        {
            // Default to inline cancel if we cannot reach the endpoint
            _canCancelInline = true;
        }
    }

    private async Task ManageSubscriptionExternal()
    {
        if (!string.IsNullOrEmpty(_manageSubscriptionUrl))
            await JSRuntime.InvokeVoidAsync("open", _manageSubscriptionUrl, "_blank");
    }

    private record CancelInfoResponse(bool CanCancelInline, string? ManageUrl);

    private async Task ToggleImageVisibility(UserImage image, object isChecked)
    {
        if (bool.TryParse(isChecked?.ToString(), out bool isVisible))
        {
            image.ImageVisible = isVisible;
            await SignalRClient.UpdateImageVisibility(image.ImageId, image.ImageVisible);
        }
    }

    private async Task ToggleReviewVisibility(UserImage image, object isChecked)
    {
        if (bool.TryParse(isChecked?.ToString(), out bool isPublic))
        {
            image.ReviewVisible = isPublic;
            await SignalRClient.UpdateReviewVisibility(image.ImageId, image.ReviewVisible);
        }
    }

    private async Task HandleProfilePictureUpload(InputFileChangeEventArgs e)
    {
        if (_isUploading)
        {
            return;
        }

        _isUploading = true;

        // Clear any previous error immediately when a new upload starts.
        _fileErrorMessage = string.Empty;
        StateHasChanged();

        try
        {
            var file = e.File;

            int result;
            Guid imageGuid;
            (result, imageGuid) = await SignalRClient.UploadPhotoAsync(file);

            if (result == 0)
            {
                var newImage = new UserImage
                    {
                        ImageGuid = imageGuid,
                        DateCreated = DateTime.UtcNow,
                        ImageVisible = true
                    };

                // Ensure the newest image is shown first.
                _userImages.Insert(0, newImage);
                _userImages = _userImages
                    .OrderByDescending(i => i.DateCreated)
                    .ToList();

                _fileErrorMessage = "";
            }
            else if (result == -1) _fileErrorMessage = $"File is too large, upload a smaller file.";
            else if (result == -2) _fileErrorMessage = $"File is not a valid image, upload an image file.";
            else if (result == -3) _fileErrorMessage = "Your face must be visible in the picture with no other people, no nudity, and you must be over 18.";
            else _fileErrorMessage = "An error occurred while uploading the image.";
        }
        finally
        {
            _isUploading = false;
            StateHasChanged();
        }
    }

    private async Task HandleVisibilityToggle(ChangeEventArgs e)
    {
        if (bool.TryParse(e.Value?.ToString(), out bool isVisible))
        {
            _profileVisible = isVisible;
            SignalRClient.CurrentUser.Searchable = isVisible;
            await UpdateUserInfo();
            _visibilityMessage = isVisible
                ? "Your profile is now visible to other users."
                : "Your profile is now hidden from search results.";
        }
    }

    private void StartDeleteFlow()
    {
        _deleteErrorMessage = string.Empty;
        _deleteStep = _profileVisible ? DeleteStep.SuggestHide : DeleteStep.ConfirmDelete;
    }

    private async Task HideInstead()
    {
        _profileVisible = false;
        SignalRClient.CurrentUser.Searchable = false;
        await UpdateUserInfo();
        _visibilityMessage = "Your profile is now hidden from search results.";
        _deleteStep = DeleteStep.None;
    }

    private void ProceedToConfirmDelete()
    {
        _deleteStep = DeleteStep.ConfirmDelete;
    }

    private void CancelDelete()
    {
        _deleteStep = DeleteStep.None;
        _deleteErrorMessage = string.Empty;
    }

    private async Task ConfirmDeleteProfile()
    {
        _deleteErrorMessage = string.Empty;
        bool success = await SignalRClient.DeleteProfileAsync();
        if (success)
        {
            if (MainLayoutInstance != null)
            {
                MainLayoutInstance.Logout();
            }
        }
        else
        {
            _deleteErrorMessage = "Unable to delete your profile. Please try again or contact support@companionation.com.";
        }
    }


}

