@page "/Admin"
@using CompanioNation.Shared
@inject NavigationManager Navigation
@inject CompanioNationSignalRClient SignalRClient

@if (!IsAdministrator)
{
    <p>You do not have permission to view this page.</p>
    <button class="btn btn-primary" @onclick="NavigateToHome">Go to Home</button>
}
else if (activeView == AdminView.Dashboard)
{
    <div class="admin-panel">
        <h3>Administrator Panel</h3>

        @* ========== Safe Section ========== *@
        <div class="tool-section tool-section-safe">
            <div class="tool-section-header">
                <span class="tool-section-icon">👤</span>
                <div>
                    <h4>User Management</h4>
                    <p class="tool-section-desc">Review and edit user profiles. Safe, read/write operations.</p>
                </div>
            </div>
            <button class="tool-card" @onclick="OpenUserEditor">
                <span class="tool-card-icon">✏️</span>
                <div class="tool-card-text">
                    <strong>User Editor</strong>
                    <span>Browse, audit, and edit user profiles and photos</span>
                </div>
                <span class="tool-card-arrow">›</span>
            </button>
        </div>

        @* ========== Moderate Section ========== *@
        <div class="tool-section tool-section-moderate">
            <div class="tool-section-header">
                <span class="tool-section-icon">🧪</span>
                <div>
                    <h4>Diagnostics</h4>
                    <p class="tool-section-desc">Test and debug tools. May produce errors in logs.</p>
                </div>
            </div>
            <div class="tool-card-row">
                <button class="tool-card" @onclick="RunTestSuite">
                    <span class="tool-card-icon">🧪</span>
                    <div class="tool-card-text">
                        <strong>Run Test Suite</strong>
                        <span>Execute integration tests</span>
                    </div>
                </button>
                <button class="tool-card" @onclick="TestError">
                    <span class="tool-card-icon">⚠️</span>
                    <div class="tool-card-text">
                        <strong>Test Error</strong>
                        <span>Throw a managed exception</span>
                    </div>
                </button>
                <button class="tool-card" onclick="TestError2()">
                    <span class="tool-card-icon">⚠️</span>
                    <div class="tool-card-text">
                        <strong>Test JS Error</strong>
                        <span>Throw a JavaScript exception</span>
                    </div>
                </button>
                <button class="tool-card" @onclick="TriggerUnobservedTaskException">
                    <span class="tool-card-icon">💥</span>
                    <div class="tool-card-text">
                        <strong>Unobserved Exception</strong>
                        <span>Fire-and-forget fault</span>
                    </div>
                </button>
            </div>
            @if (!string.IsNullOrWhiteSpace(testResult) && testResult != "{}")
            {
                <p class="maintenance-result">Test result: @testResult</p>
            }
        </div>

        @* ========== Danger Section ========== *@
        <div class="tool-section tool-section-danger">
            <div class="tool-section-header">
                <span class="tool-section-icon">🔴</span>
                <div>
                    <h4>Danger Zone</h4>
                    <p class="tool-section-desc">Destructive operations. Daily maintenance regenerates CompanioNita's column, creating duplicates for the day. Use only as a last resort.</p>
                </div>
            </div>
            <button class="tool-card tool-card-danger" @onclick="ExecuteMaintenance" disabled="@isMaintenanceRunning">
                <span class="tool-card-icon">🔧</span>
                <div class="tool-card-text">
                    <strong>Run Daily Maintenance</strong>
                    <span>Regenerates CompanioNita column — will create duplicates if already run today</span>
                </div>
            </button>

            @if (isMaintenanceRunning)
            {
                <div class="spinner-container">
                    <div class="spinner"></div>
                    <p class="maintenance-message">Daily maintenance is in progress...</p>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(maintenanceResult))
            {
                <p class="@GetResultClass()">@maintenanceResult</p>
            }
        </div>
    </div>
}
else if (activeView == AdminView.UserEditor)
{
    <div class="user-editor-layout">
        @* Hamburger toggle *@
        <button class="ue-expand-button" @onclick="ToggleUserSidebar" title="Toggle user list">☰</button>

        @* Sidebar with user list *@
        <div class="ue-sidebar @(userSidebarCollapsed ? "collapsed" : "")">
            <div class="ue-sidebar-header">
                <h4>Users</h4>
                <button class="btn btn-sm btn-outline-light ue-back-btn" @onclick="BackToDashboard">← Back</button>
            </div>

            @if (isLoadingProfiles)
            {
                <div class="ue-loading">
                    <div class="spinner"></div>
                    <p>Loading…</p>
                </div>
            }
            else if (flaggedProfiles == null || flaggedProfiles.Count == 0)
            {
                <p class="ue-empty">No profiles found.</p>
                <button class="btn btn-sm btn-outline-light" style="margin: 0 8px;" @onclick="LoadFlaggedProfiles">Refresh</button>
            }
            else
            {
                <div class="ue-user-list">
                    @foreach (var profile in flaggedProfiles)
                    {
                        <div class="ue-user-item @(auditProfile?.UserId == profile.UserId ? "active" : "")"
                             @onclick="() => SelectUser(profile.UserId)">
                            <img src="@Util.GetPhotoUrl(profile.Thumbnail)" alt="@profile.Name" class="ue-user-thumb" />
                            <div class="ue-user-info">
                                <span class="ue-user-name">@profile.Name</span>
                                <span class="ue-user-meta">@Util.GetGenderString(profile.Gender) · Rank @profile.Ranking</span>
                            </div>
                        </div>
                    }
                </div>

                <div class="ue-pagination">
                    <button class="btn btn-sm btn-outline-light" disabled="@(currentOffset == 0)" @onclick="PreviousPage">←</button>
                    <span>Page @(currentOffset / pageSize + 1)</span>
                    <button class="btn btn-sm btn-outline-light" disabled="@(flaggedProfiles.Count < pageSize)" @onclick="NextPage">→</button>
                </div>
            }
        </div>

        @* Detail pane *@
        <div class="ue-detail @(userSidebarCollapsed ? "expanded" : "")" @onclick="HandleDetailClick">
            @if (isLoadingAudit)
            {
                <div class="ue-loading">
                    <div class="spinner"></div>
                    <p>Loading profile details…</p>
                </div>
            }
            else if (auditProfile != null)
            {
                @* User header with photo strip *@
                <div class="ue-detail-header">
                    <div class="ue-detail-title">
                        <h4>@auditProfile.Name <span class="ue-detail-id">(ID: @auditProfile.UserId)</span></h4>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="CloseAudit">✕</button>
                    </div>
                </div>

                @* Info grid *@
                <div class="ue-info-grid">
                    <div><b>Email:</b> @auditProfile.Email</div>
                    <div><b>Gender:</b> @Util.GetGenderString(auditProfile.Gender)</div>
                    <div><b>DOB:</b> @(auditProfile.DateOfBirth?.ToString("d") ?? "Not set")</div>
                    <div><b>Ranking:</b> @auditProfile.Ranking</div>
                    <div><b>Searchable:</b> @(auditProfile.Searchable ? "Yes" : "No")</div>
                    <div><b>Member since:</b> @auditProfile.DateCreated.ToString("d")</div>
                    <div><b>Last login:</b> @(auditProfile.LastLogin?.ToString("g") ?? "Never")</div>
                    <div><b>Location:</b> @auditProfile.CityDisplayName</div>
                </div>

                @* Edit form *@
                <div class="ue-edit-section">
                    <h5>Edit Profile</h5>
                    <div class="ue-edit-field">
                        <label>Name:</label>
                        <input type="text" maxlength="15" @bind="editName" class="form-control form-control-sm" />
                    </div>
                    <div class="ue-edit-field">
                        <label>Description:</label>
                        <textarea @bind="editDescription" class="form-control form-control-sm" rows="4" maxlength="4096"></textarea>
                    </div>
                    <div class="ue-edit-row">
                        <div class="ue-edit-field">
                            <label>Gender:</label>
                            <select @bind="editGender" class="form-control form-control-sm">
                                <option value="0">Unknown</option>
                                <option value="2">Male</option>
                                <option value="4">Female</option>
                                <option value="8">Other</option>
                                <option value="16">Trans Male</option>
                                <option value="32">Trans Female</option>
                            </select>
                        </div>
                        <div class="ue-edit-field">
                            <label>Searchable:</label>
                            <select @bind="editSearchable" class="form-control form-control-sm">
                                <option value="true">Yes</option>
                                <option value="false">No</option>
                            </select>
                        </div>
                    </div>
                    <div class="ue-edit-actions">
                        <button class="btn btn-primary btn-sm" @onclick="SaveProfileEdits" disabled="@isSaving">
                            @(isSaving ? "Saving..." : "Save Changes")
                        </button>
                    </div>
                </div>

                @* Photos *@
                <div class="ue-photos-section">
                    <h5>Photos (@auditProfile.Photos.Count)</h5>
                    @if (auditProfile.Photos.Count == 0)
                    {
                        <p class="text-muted">No photos.</p>
                    }
                    else
                    {
                        <div class="ue-photo-grid">
                            @foreach (var photo in auditProfile.Photos)
                            {
                                <div class="ue-photo-card">
                                    <img src="@Util.GetPhotoUrl(photo.ImageGuid)" alt="Photo @photo.ImageId" class="ue-photo-img" />
                                    <div class="ue-photo-meta">
                                        <span class="@(photo.ImageVisible ? "photo-visible" : "photo-hidden")">
                                            @(photo.ImageVisible ? "Visible" : "Hidden")
                                        </span>
                                        <span>@photo.DateCreated.ToString("d")</span>
                                    </div>
                                    @if (photoBeingDeleted == photo.ImageId)
                                    {
                                        <div class="ue-delete-confirm">
                                            <span>Delete this photo?</span>
                                            <button class="btn btn-danger btn-sm" @onclick="() => ConfirmDeletePhoto(photo.ImageId)">Yes</button>
                                            <button class="btn btn-secondary btn-sm" @onclick="CancelDeletePhoto">No</button>
                                        </div>
                                    }
                                    else
                                    {
                                        <button class="btn btn-outline-danger btn-sm" @onclick="() => StartDeletePhoto(photo.ImageId)">Delete</button>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>

                @* Description preview *@
                <div class="ue-description">
                    <h5>Current Description</h5>
                    <div class="ue-description-text">@auditProfile.Description</div>
                </div>

                @* Actions *@
                <div class="ue-actions">
                    <button class="btn btn-success" @onclick="DismissProfile" disabled="@isDismissing">
                        @(isDismissing ? "Dismissing..." : "✓ Approve & Dismiss")
                    </button>
                </div>

                @if (!string.IsNullOrWhiteSpace(auditMessage))
                {
                    <p class="@(auditMessageIsError ? "maintenance-error" : "maintenance-result")">@auditMessage</p>
                }
            }
            else
            {
                <div class="ue-empty-detail">
                    <p>← Select a user from the list to view their profile</p>
                </div>
            }
        </div>
    </div>
}
<script>
    function TestError2() {
        throw new Error("test javascript error");
    }
</script>

@code {
    private enum AdminView { Dashboard, UserEditor }

    private bool IsAdministrator = false;
    private AdminView activeView = AdminView.Dashboard;

    // Maintenance
    private string maintenanceResult = string.Empty;
    private bool isMaintenanceRunning = false;

    // Profile triage
    private List<UserDetails> flaggedProfiles;
    private bool isLoadingProfiles = false;
    private int currentOffset = 0;
    private const int pageSize = 20;

    // Audit
    private UserDetails auditProfile;
    private bool isLoadingAudit = false;
    private string editName = string.Empty;
    private string editDescription = string.Empty;
    private int editGender = 0;
    private bool editSearchable = true;
    private bool isSaving = false;
    private bool isDismissing = false;
    private int? photoBeingDeleted = null;
    private string auditMessage = string.Empty;
    private bool auditMessageIsError = false;

    // User editor sidebar
    private bool userSidebarCollapsed = false;

    protected override async Task OnInitializedAsync()
    {
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var currentUser = SignalRClient.CurrentUser;
            if (currentUser != null && currentUser.IsAdministrator)
            {
                IsAdministrator = true;
                StateHasChanged();
            }
            else
            {
                StateHasChanged();
            }
        }
    }

    // ========== Navigation ==========

    private async Task OpenUserEditor()
    {
        activeView = AdminView.UserEditor;
        await LoadFlaggedProfiles();
    }

    private void BackToDashboard()
    {
        activeView = AdminView.Dashboard;
        auditProfile = null;
        auditMessage = string.Empty;
    }

    private void ToggleUserSidebar()
    {
        userSidebarCollapsed = !userSidebarCollapsed;
    }

    private void HandleDetailClick()
    {
        // On mobile, collapse sidebar when tapping the detail pane
        if (!userSidebarCollapsed)
            userSidebarCollapsed = true;
    }

    private async Task SelectUser(int userId)
    {
        await LoadProfileForAudit(userId);
        // Auto-collapse sidebar on selection for smaller screens
        userSidebarCollapsed = true;
    }

    // ========== Triage List ==========

    private async Task LoadFlaggedProfiles()
    {
        isLoadingProfiles = true;
        StateHasChanged();

        try
        {
            var result = await SignalRClient.AdminGetFlaggedProfilesAsync(currentOffset, pageSize);
            flaggedProfiles = result.IsSuccess ? result.Data : new List<UserDetails>();
        }
        catch (Exception ex)
        {
            flaggedProfiles = new List<UserDetails>();
        }
        finally
        {
            isLoadingProfiles = false;
            StateHasChanged();
        }
    }

    private async Task PreviousPage()
    {
        if (currentOffset >= pageSize)
            currentOffset -= pageSize;
        else
            currentOffset = 0;

        await LoadFlaggedProfiles();
    }

    private async Task NextPage()
    {
        currentOffset += pageSize;
        await LoadFlaggedProfiles();
    }

    // ========== Audit Detail ==========

    private async Task LoadProfileForAudit(int userId)
    {
        isLoadingAudit = true;
        auditMessage = string.Empty;
        photoBeingDeleted = null;
        StateHasChanged();

        try
        {
            var result = await SignalRClient.AdminGetProfileForAuditAsync(userId);
            if (result.IsSuccess)
            {
                auditProfile = result.Data;
                editName = auditProfile.Name;
                editDescription = auditProfile.Description;
                editGender = auditProfile.Gender ?? 0;
                editSearchable = auditProfile.Searchable;
            }
            else
            {
                auditProfile = null;
                SetAuditMessage(true, result.Message);
            }
        }
        catch (Exception ex)
        {
            auditProfile = null;
            SetAuditMessage(true, "Error loading profile.");
        }
        finally
        {
            isLoadingAudit = false;
            StateHasChanged();
        }
    }

    private void CloseAudit()
    {
        auditProfile = null;
        auditMessage = string.Empty;
    }

    private async Task SaveProfileEdits()
    {
        if (auditProfile == null) return;
        isSaving = true;
        auditMessage = string.Empty;
        StateHasChanged();

        try
        {
            var updatedDetails = new UserDetails
            {
                UserId = auditProfile.UserId,
                Name = editName,
                Description = editDescription,
                Gender = editGender,
                Searchable = editSearchable,
                Geonameid = auditProfile.Geonameid,
                DateOfBirth = auditProfile.DateOfBirth
            };

            var result = await SignalRClient.AdminUpdateProfileAsync(updatedDetails);
            if (result.IsSuccess)
            {
                SetAuditMessage(false, "Profile saved.");
                // Refresh the audit panel
                await LoadProfileForAudit(auditProfile.UserId);
            }
            else
            {
                SetAuditMessage(true, result.Message);
            }
        }
        catch (Exception ex)
        {
            SetAuditMessage(true, "Error saving profile.");
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }

    // ========== Photo Management ==========

    private void StartDeletePhoto(int imageId)
    {
        photoBeingDeleted = imageId;
    }

    private void CancelDeletePhoto()
    {
        photoBeingDeleted = null;
    }

    private async Task ConfirmDeletePhoto(int imageId)
    {
        if (auditProfile == null) return;

        try
        {
            var result = await SignalRClient.AdminDeletePhotoAsync(auditProfile.UserId, imageId);
            if (result.IsSuccess)
            {
                SetAuditMessage(false, "Photo deleted.");
                auditProfile.Photos.RemoveAll(p => p.ImageId == imageId);
            }
            else
            {
                SetAuditMessage(true, result.Message);
            }
        }
        catch (Exception ex)
        {
            SetAuditMessage(true, "Error deleting photo.");
        }
        finally
        {
            photoBeingDeleted = null;
            StateHasChanged();
        }
    }

    // ========== Dismiss ==========

    private async Task DismissProfile()
    {
        if (auditProfile == null) return;
        isDismissing = true;
        StateHasChanged();

        try
        {
            var result = await SignalRClient.AdminDismissProfileAsync(auditProfile.UserId);
            if (result.IsSuccess)
            {
                SetAuditMessage(false, "Profile dismissed.");
                // Remove from list and close audit
                flaggedProfiles?.RemoveAll(p => p.UserId == auditProfile.UserId);
                auditProfile = null;
            }
            else
            {
                SetAuditMessage(true, result.Message);
            }
        }
        catch (Exception ex)
        {
            SetAuditMessage(true, "Error dismissing profile.");
        }
        finally
        {
            isDismissing = false;
            StateHasChanged();
        }
    }

    // ========== Helpers ==========

    private void SetAuditMessage(bool isError, string message)
    {
        auditMessageIsError = isError;
        auditMessage = message;
    }

    // ========== Existing Admin Methods ==========

    private async Task ExecuteMaintenance()
    {
        isMaintenanceRunning = true;
        maintenanceResult = string.Empty;

        try
        {
            maintenanceResult = await SignalRClient.TriggerMaintenanceManually();
        }
        catch (Exception ex)
        {
            maintenanceResult = $"Error: {ex.Message}";
        }
        finally
        {
            isMaintenanceRunning = false;
        }
    }

    private string GetResultClass()
    {
        return maintenanceResult.StartsWith("Error:") ? "maintenance-error" : "maintenance-result";
    }

    private void NavigateToHome()
    {
        Navigation.NavigateTo("/");
    }

    // Test functionality
    private string testResult = "{}";

    public async Task RunTestSuite()
    {
        testResult = await SignalRClient.RunTestSuite();
    }

    private async void TestError()
    {
        throw new InvalidOperationException("Test exception thrown by TestErrorComponent.");
    }

    public void TriggerUnobservedTaskException()
    {
        var faultyTask = Task.Run(() =>
        {
            throw new InvalidOperationException("This is an unobserved exception");
        });
    }
}
