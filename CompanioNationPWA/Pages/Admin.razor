    // ========== Guarantor → LINK Migration ==========

    private async Task RunGuarantorMigration()
    {
        _isMigrationRunning = true;
        _migrationResult = null;
        _migrationMessage = "";
        _migrationIsError = false;
        StateHasChanged();

        try
        {
            var result = await SignalRClient.MigrateGuarantorDataAsync();
            if (result != null)
            {
                _migrationResult = result;
                _migrationMessage = $"Migration complete. {result.Migrated} images migrated.";
            }
            else
            {
                _migrationMessage = "Migration failed. Check server logs for details.";
                _migrationIsError = true;
            }
        }
        catch (Exception ex)
        {
            _migrationMessage = $"Error: {ex.Message}";
            _migrationIsError = true;
        }
        finally
        {
            _isMigrationRunning = false;
            StateHasChanged();
        }
    }
