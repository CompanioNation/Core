@page "/PrivacyPolicy"
@inject NavigationManager NavigationManager

@* Privacy policy content is served by the server-rendered endpoint
   (PrivacyPolicyEndpoints.cs) so bots can read it without JavaScript.
   This Blazor route forces a full server navigation to that endpoint. *@

@code {
    protected override void OnInitialized()
    {
        NavigationManager.NavigateTo("/PrivacyPolicy", forceLoad: true);
    }
}
