{
  "name": "CompanioNation™",
  "short_name": "CompanioNation™",
  "id": "./",
  "lang": "en",
  "dir": "ltr",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "display_override": [ "standalone" ],
  "orientation": "natural",
  "background_color": "#ffffff",
  "theme_color": "#03173d",
  "description": "CompanioNation™ is the first ever open-source dating app. No paywalls, no swipe games — just message people you're interested in. The LINK algorithm keeps bots and scammers out. CompanioNation profits from your success, not your clicks. No other dating app is built like this.",
  "prefer_related_applications": false,
  "related_applications": [],
  "icons": [
    {
      "src": "icons/120.png",
      "type": "image/png",
      "sizes": "120x120",
      "purpose": "any"
    },
    {
